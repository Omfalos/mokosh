{
  "name": "@omfalos/mokosh",
  "version": "0.1.1",
  "description": "A high-performance, AST-powered dependency graph generator for frontend projects, optimized for AI context and smart test selection.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Omfalos/mokosh.git"
  },
  "bugs": {
    "url": "https://github.com/Omfalos/mokosh/issues"
  },
  "homepage": "https://github.com/Omfalos/mokosh#readme",
  "bin": {
    "mokosh": "./dist/cli.js",
    "mokosh-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "build:prod": "NODE_ENV=production tsup",
    "lint": "biome lint ./src",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "example": "tsx example/run-example.ts",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -o CHANGELOG.md",
    "prepublishOnly": "npm run build:prod",
    "prepare": "husky"
  },
  "keywords": [
    "dependency-graph",
    "ast",
    "typescript",
    "frontend",
    "ai-ready",
    "rag",
    "test-impact-analysis",
    "mermaid"
  ],
  "author": "Omfalos",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json}": [
      "biome check --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/coffeescript": "^2.5.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "coffeescript": "^2.7.0",
    "conventional-changelog": "^8.0.1",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "livescript": "^1.6.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/gherkin-streams": "^6.0.0",
    "@cucumber/gherkin-utils": "^11.0.0",
    "@cucumber/messages": "^32.2.0",
    "@lezer/go": "^1.0.1",
    "@lezer/python": "^1.1.18",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/luaparse": "^0.2.13",
    "js-yaml": "^4.1.1",
    "luaparse": "^0.3.1",
    "postcss": "^8.5.12",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "stylus": "^0.64.0"
  }
}
